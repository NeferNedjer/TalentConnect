{% extends 'base.html.twig' %}

{% block title %}Connexion | TalentConnect{% endblock %}

{% block body_class %}auth-page{% endblock %}

{% block nav_overlay %}{% endblock %}
{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block stylesheets %}
  {{ parent() }}
{% endblock %}

{% block body %}
<div class="auth-layout">
  {% include 'partials/_auth_hero.html.twig' %}

  <main class="auth-main">
    <div class="auth-card reveal">
      <a href="/" class="auth-card__back">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Retour à l'accueil
      </a>

      <h1 class="auth-card__title">Accédez à votre espace TalentConnect</h1>
      <p class="auth-card__subtitle">Connectez-vous pour gérer votre profil, vos opportunités et vos messages.</p>

      {% include 'partials/_auth_stats_mobile.html.twig' %}

      {% if error %}
        <div class="auth-alert auth-alert--error" role="alert">
          {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
      {% endif %}

      {% if app.user %}
        <div class="auth-alert auth-alert--info">
          Vous êtes connecté en tant que {{ app.user.userIdentifier }},
          <a href="{{ path('app_logout') }}" class="auth-form__link">Se déconnecter</a>
        </div>
      {% endif %}

      <form class="auth-form" method="post" action="{{ path('app_login') }}">
        <div class="form-group">
          <label class="form-group__label" for="inputEmail">Email</label>
          <input
            type="email"
            value="{{ last_username }}"
            name="email"
            id="inputEmail"
            class="form-group__input"
            placeholder="vous@exemple.fr"
            autocomplete="email"
            required
            autofocus
          >
        </div>

        <div class="form-group">
          <label class="form-group__label" for="inputPassword">Mot de passe</label>
          <input
            type="password"
            name="password"
            id="inputPassword"
            class="form-group__input"
            placeholder="••••••••"
            autocomplete="current-password"
            required
          >
        </div>

        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        <div class="auth-form__row">
          <label class="form-check form-check--inline" for="remember_me">
            <input type="checkbox" name="_remember_me" id="remember_me">
            <span class="form-check__box" aria-hidden="true"></span>
            <span class="form-check__label">Se souvenir de moi</span>
          </label>
          <a href="#" class="auth-form__link" data-forgot-password>Mot de passe oublié</a>
        </div>

        <button type="submit" class="btn btn--primary btn--block auth-form__submit">Se connecter</button>
      </form>

      {# MVP : OAuth masqué — réactiver pour une version ultérieure
      <div class="auth-divider"><span>ou</span></div>

      <div class="auth-social">
        <button type="button" class="btn btn--social btn--block" data-oauth="google">
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Continuer avec Google
        </button>
        <button type="button" class="btn btn--social btn--block" data-oauth="apple">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
          Continuer avec Apple
        </button>
      </div>
      #}

      <p class="auth-card__footer">
        Pas encore de compte ?
        <a href="{{ path('app_register') }}" class="auth-form__link auth-form__link--bold">Créer un compte</a>
      </p>
    </div>
  </main>
</div>
{% endblock %}
