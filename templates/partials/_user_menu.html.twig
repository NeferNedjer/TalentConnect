{# Menu utilisateur connecté — {% include 'partials/_user_menu.html.twig' %} #}
{% set has_profile = app.user.artistProfile is not null or app.user.professionalProfile is not null %}
{% set user_label = app.user.firstname ? app.user.firstname : 'Mon espace' %}

{% if app.user.artistProfile %}
  {% set profile_url = path('app_artist_profile_edit') %}
  {% set profile_label = 'Profil artiste' %}
{% elseif app.user.professionalProfile %}
  {% set profile_url = path('app_professional_profile_edit') %}
  {% set profile_label = 'Profil professionnel' %}
{% else %}
  {% set profile_url = path('app_my_profile') %}
  {% set profile_label = 'Créer mon profil' %}
{% endif %}

<div class="user-menu" data-user-menu>
  <button
    type="button"
    class="user-menu__trigger"
    id="user-menu-trigger"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-controls="user-menu-dropdown"
  >
    <span class="user-menu__avatar" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
    </span>
    <span class="user-menu__label">{{ user_label }}</span>
    <span class="user-menu__chevron" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </span>
  </button>

  <div
    class="user-menu__dropdown"
    id="user-menu-dropdown"
    role="menu"
    aria-labelledby="user-menu-trigger"
    hidden
  >
    <ul class="user-menu__list">
      <li role="none">
        <a href="{{ path('app_dashboard') }}" class="user-menu__item" role="menuitem" tabindex="-1">
          <span class="user-menu__item-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          </span>
          Tableau de bord
        </a>
      </li>
      <li class="user-menu__separator" role="separator"></li>
      <li role="none">
        <a href="{{ profile_url }}" class="user-menu__item" role="menuitem" tabindex="-1">
          <span class="user-menu__item-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </span>
          {{ profile_label }}
        </a>
      </li>
      {% if has_profile %}
        <li role="none">
          <a href="{{ path('app_dashboard_announcements') }}" class="user-menu__item" role="menuitem" tabindex="-1">
            <span class="user-menu__item-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </span>
            Mes annonces
          </a>
        </li>
      {% endif %}
      <li class="user-menu__separator" role="separator"></li>
      <li role="none">
        <a href="{{ path('app_logout') }}" class="user-menu__item user-menu__item--logout" role="menuitem" tabindex="-1">
          <span class="user-menu__item-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          </span>
          Déconnexion
        </a>
      </li>
    </ul>
  </div>
</div>
