{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}TalentConnect Administration{% endblock %}

{% block main %}
    <p class="content-header-help mb-4">Tableau de bord de la plateforme.</p>

    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small mb-1">👤 Utilisateurs</div>
                    <div class="fs-2 fw-bold">{{ stats.users }}</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small mb-1">🎤 Artistes</div>
                    <div class="fs-2 fw-bold">{{ stats.artists }}</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small mb-1">🏢 Professionnels</div>
                    <div class="fs-2 fw-bold">{{ stats.professionals }}</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small mb-1">🎬 Vidéos</div>
                    <div class="fs-2 fw-bold text-muted">{{ stats.videos }}</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small mb-1">📢 Opportunités</div>
                    <div class="fs-2 fw-bold text-muted">{{ stats.opportunities }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="content-panel mb-4">
        <div class="content-panel-header">
            <h2 class="h5 mb-0">Dernières inscriptions</h2>
        </div>
        <div class="content-panel-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Rôles</th>
                        <th>Date de création</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in latestUsers %}
                        <tr>
                            <td>{{ user.email }}</td>
                            <td>
                                {% if user.roles is not empty %}
                                    {% for role in user.roles %}
                                        <span class="badge bg-secondary">{{ role }}</span>
                                    {% endfor %}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>{{ user.createdAt|date('d/m/Y H:i') }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">Aucun utilisateur inscrit pour le moment.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a href="{{ urls.users }}" class="btn btn-primary">
            Gérer les utilisateurs
        </a>
        <a href="{{ urls.artists }}" class="btn btn-secondary">
            Gérer les artistes
        </a>
        <a href="{{ urls.professionals }}" class="btn btn-secondary">
            Gérer les professionnels
        </a>
        <a href="{{ urls.home }}" class="btn btn-secondary">
            Retour au site
        </a>
    </div>
{% endblock %}
