{% extends 'base.html.twig' %}

{% block title %}Inscription | TalentConnect{% endblock %}

{% block body_class %}auth-page auth-page--register{% endblock %}

{% block nav_overlay %}{% endblock %}
{% block header %}{% endblock %}

{% block body %}
<div class="auth-layout auth-layout--register">
  {% include 'partials/_auth_hero.html.twig' %}

  <main class="auth-main">
    <div class="auth-card auth-card--register reveal">
      <a href="/" class="auth-card__back">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Retour à l'accueil
      </a>

      <h1 class="auth-card__title">Créer votre compte TalentConnect</h1>
      <p class="auth-card__subtitle">Rejoignez la plateforme dédiée aux artistes et aux professionnels de la musique.</p>

      {% include 'partials/_auth_stats_mobile.html.twig' %}

      {{ form_start(registrationForm, {
        attr: {
          class: 'auth-form auth-form--register',
          'data-register-form': 'true',
          novalidate: 'novalidate'
        }
      }) }}

        {% if registrationForm.vars.errors|length > 0 %}
          <div class="auth-alert auth-alert--error" role="alert">
            {{ form_errors(registrationForm) }}
          </div>
        {% endif %}

        <div class="form-group">
          {{ form_label(registrationForm.email, 'Adresse e-mail', { label_attr: { class: 'form-group__label' } }) }}
          {{ form_widget(registrationForm.email, {
            attr: {
              class: 'form-group__input',
              placeholder: 'vous@exemple.fr',
              autocomplete: 'email'
            }
          }) }}
          {{ form_errors(registrationForm.email) }}
        </div>

        <div class="form-group">
          {{ form_label(registrationForm.plainPassword, 'Mot de passe', { label_attr: { class: 'form-group__label' } }) }}
          {{ form_widget(registrationForm.plainPassword, {
            attr: {
              class: 'form-group__input',
              placeholder: '••••••••',
              autocomplete: 'new-password',
              'data-password-main': 'true'
            }
          }) }}
          {{ form_errors(registrationForm.plainPassword) }}
        </div>

        {% if registrationForm.plainPasswordConfirm is defined %}
          <div class="form-group">
            {{ form_label(registrationForm.plainPasswordConfirm, 'Confirmation du mot de passe', { label_attr: { class: 'form-group__label' } }) }}
            {{ form_widget(registrationForm.plainPasswordConfirm, {
              attr: {
                class: 'form-group__input',
                placeholder: '••••••••',
                autocomplete: 'new-password'
              }
            }) }}
            {{ form_errors(registrationForm.plainPasswordConfirm) }}
          </div>
        {% else %}
          <div class="form-group form-group--compact">
            <label class="form-group__label" for="password_confirm_visual">Confirmation du mot de passe</label>
            <input
              type="password"
              id="password_confirm_visual"
              class="form-group__input"
              placeholder="••••••••"
              autocomplete="new-password"
              data-password-confirm="true"
              aria-describedby="password_confirm_hint"
            >
            <span id="password_confirm_hint" class="form-hint form-hint--compact">Identique au mot de passe saisi.</span>
            <span class="form-error-msg" data-password-confirm-error hidden>Les mots de passe ne correspondent pas.</span>
          </div>
        {% endif %}

        <div class="form-group form-group--terms">
          <label class="form-check form-check--inline form-check--terms" for="{{ registrationForm.agreeTerms.vars.id }}">
            {{ form_widget(registrationForm.agreeTerms, { label: false, attr: { class: 'form-check__input' } }) }}
            <span class="form-check__box" aria-hidden="true"></span>
            <span class="form-check__label">J'accepte les conditions d'utilisation</span>
          </label>
          {{ form_errors(registrationForm.agreeTerms) }}
        </div>

        <button type="submit" class="btn btn--primary btn--block auth-form__submit auth-form__submit--register">Créer mon compte</button>

      {{ form_end(registrationForm) }}

      <p class="auth-card__footer">
        Déjà inscrit ?
        <a href="{{ path('app_login') }}" class="auth-form__link auth-form__link--bold auth-form__link--footer">Se connecter</a>
      </p>
    </div>
  </main>
</div>
{% endblock %}
