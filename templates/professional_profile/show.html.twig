{% extends 'base.html.twig' %}

{% block title %}{{ profile.companyName|trim is not empty ? profile.companyName ~ ' — TalentConnect' : 'Profil professionnel | TalentConnect' }}{% endblock %}

{% block body_class %}artist-profile-show-page{% endblock %}

{% block body %}
{% set professional_type_labels = {
  'label': 'Label',
  'studio': 'Studio',
  'producteur': 'Producteur',
  'manager': 'Manager',
  'festival': 'Festival',
  'salle': 'Salle',
  'organisateur': 'Organisateur',
  'other': 'Autre'
} %}
{% set display_name = profile.companyName|trim is not empty ? profile.companyName : 'Professionnel TalentConnect' %}
{% set initials = profile.companyName|trim is not empty
  ? (profile.companyName|split(' ')|slice(0, 2)|map(v => v|slice(0, 1)|upper)|join)
  : '?'
%}

<main>
  <div class="profile-banner profile-banner--placeholder" aria-hidden="true">
    <div class="profile-banner__overlay"></div>
  </div>

  <section class="profile-header">
    <div class="container">
      <div class="profile-header__inner">
        <div class="profile-header__avatar profile-header__avatar--placeholder profile-header__avatar--logo" aria-hidden="true">
          <span>{{ initials }}</span>
        </div>

        <div class="profile-header__info">
          <h1 class="profile-header__name">{{ display_name }}</h1>
          <div class="profile-header__meta">
            <span class="profile-header__meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4"/></svg>
              {{ professional_type_labels[profile.type]|default(profile.type) }}
            </span>
            {% if profile.city or profile.country %}
              <span class="profile-header__meta-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {{ [profile.city, profile.region, profile.country]|filter(v => v)|join(', ') }}
              </span>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container artist-profile-show__content">
    {% if profile.description %}
      <section class="profile-bio reveal">
        <h2 class="profile-bio__title">Présentation</h2>
        <div class="profile-bio__text">
          <p>{{ profile.description|nl2br }}</p>
        </div>
      </section>
    {% endif %}

    {% if profile.website or profile.emailPublic or profile.telephonePublic %}
      <section class="profile-section reveal">
        <h2 class="profile-section__title">Coordonnées</h2>
        <ul class="profile-links">
          {% if profile.website %}
            <li>
              <a href="{{ profile.website }}" class="profile-links__item" target="_blank" rel="noopener noreferrer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                Site web
              </a>
            </li>
          {% endif %}
          {% if profile.emailPublic %}
            <li>
              <a href="mailto:{{ profile.emailPublic }}" class="profile-links__item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                {{ profile.emailPublic }}
              </a>
            </li>
          {% endif %}
          {% if profile.telephonePublic %}
            <li>
              <a href="tel:{{ profile.telephonePublic|replace({' ': ''}) }}" class="profile-links__item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {{ profile.telephonePublic }}
              </a>
            </li>
          {% endif %}
        </ul>
      </section>
    {% endif %}
  </div>
</main>
{% endblock %}
