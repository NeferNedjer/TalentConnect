{% extends 'base.html.twig' %}

{% block title %}TalentConnect — Découvrez les talents musicaux de demain{% endblock %}

{% block body_class %}page-home{% endblock %}

{% block stylesheets %}
<style>
  .page-home {
    --hero-bg-image: url('{{ asset('images/hero/concert.jpg') }}');
  }
</style>
{% endblock %}

{% block body %}
{% if app.user %}
  {% if app.user.artistProfile is null and app.user.professionalProfile is null %}
    {% set cta_artist_url = path('app_choose_profile') %}
    {% set cta_pro_url = path('app_choose_profile') %}
  {% else %}
    {% set cta_artist_url = path('app_my_profile') %}
    {% set cta_pro_url = path('app_my_profile') %}
  {% endif %}
{% else %}
  {% set cta_artist_url = path('app_register') %}
  {% set cta_pro_url = path('app_register') %}
{% endif %}

<main>
  <!-- Hero principal -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="hero__content">
      <span class="hero__badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Scène live · Découverte de talents
      </span>

      <h1 class="hero__title">
        Découvrez les <span>talents musicaux</span> de demain
      </h1>

      <p class="hero__subtitle">
        La plateforme qui connecte les artistes émergents aux professionnels de la musique.
      </p>

      <div class="hero__actions">
        <a href="{{ cta_artist_url }}" class="btn btn--primary">Je suis artiste</a>
        <a href="{{ cta_pro_url }}" class="btn btn--secondary">Je suis professionnel</a>
      </div>

      <!-- Barre de recherche centrale -->
      <div class="hero__search">
        {# TODO: brancher la recherche vers la future route dédiée #}
        <form class="search-bar" data-search-form role="search" aria-label="Rechercher un artiste" action="#" method="get">
          <svg class="search-bar__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="search" name="q" class="search-bar__input" placeholder="Rechercher un artiste, un genre, une ville…" aria-label="Terme de recherche">
          <button type="submit" class="search-bar__btn">Rechercher</button>
        </form>
      </div>

      <div class="hero__stats">
        <div class="hero__stat">
          <div class="hero__stat-value">2 400+</div>
          <div class="hero__stat-label">Artistes inscrits</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-value">850+</div>
          <div class="hero__stat-label">Professionnels</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-value">15K+</div>
          <div class="hero__stat-label">Vidéos publiées</div>
        </div>
      </div>
    </div>
  </section>

