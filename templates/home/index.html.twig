{% extends 'base.html.twig' %}

{% block title %}TalentConnect — La scène musicale commence ici

{% endblock %}

{% block body_class %}page-home
{% endblock %}

{% block stylesheets %}
	<style>
		.page-home {
			--hero-bg-image: url('{{ asset('images/hero/concert.jpg') }}');
		}
	</style>
{% endblock %}

{% block body %}
	{% if app.user %}
		{% if app.user.artistProfile is null and app.user.professionalProfile is null %}
			{% set cta_artist_url = path('app_choose_profile') %}
		{% else %}
			{% set cta_artist_url = path('app_my_profile') %}
		{% endif %}
	{% else %}
		{% set cta_artist_url = path('app_register') %}
	{% endif %}
	{% set cta_artist_label = app.user and (app.user.artistProfile or app.user.professionalProfile) ? 'Voir mon profil' : 'Créer mon profil' %}
	{% set cta_announcements_url = '#' %}

	<main>
		<!-- Hero principal -->
		<section class="hero">
			<div class="hero__bg" aria-hidden="true"></div>
			<div class="hero__content">
				<h1 class="hero__title">
					La
					<span>scène musicale</span>
					commence ici
				</h1>

				<p class="hero__subtitle">
					Créez votre profil, publiez vos annonces et trouvez les bonnes collaborations.
				</p>

				<div class="hero__actions">
					<a href="{{ cta_artist_url }}" class="btn btn--primary">{{ cta_artist_label }}</a>
					<a href="{{ cta_announcements_url }}" class="btn btn--secondary">Découvrir les annonces</a>
				</div>

				<!-- Barre de recherche centrale -->
				<div
					class="hero__search">
					{# TODO: brancher la recherche vers la future route dédiée #}
					<form class="search-bar" data-search-form role="search" aria-label="Rechercher un artiste" action="#" method="get">
						<svg class="search-bar__icon" width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
						</svg>
						<input type="search" name="q" class="search-bar__input" placeholder="Rechercher un artiste, un genre, une ville…" aria-label="Terme de recherche">
						<button type="submit" class="search-bar__btn">Rechercher</button>
					</form>
				</div>

				<div class="hero__stats">
					<div class="hero__stat">
						<div class="hero__stat-value">{{ stats.artists|number_format(0, ',', ' ') }}</div>
						<div class="hero__stat-label">Artistes inscrits</div>
					</div>
					<div class="hero__stat">
						<div class="hero__stat-value">{{ stats.professionals|number_format(0, ',', ' ') }}</div>
						<div class="hero__stat-label">Professionnels</div>
					</div>
					<div class="hero__stat">
						<div class="hero__stat-value">{{ stats.announcements|number_format(0, ',', ' ') }}</div>
						<div class="hero__stat-label">Annonces publiées</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Section : Artistes en vedette -->
		<section class="section section--dark" id="artistes-vedette">
			<div class="container">
				<div class="section__header reveal">
					<div>
						<h2 class="section__title">Artistes en vedette</h2>
						<p class="section__subtitle">Les talents qui font vibrer la scène musicale française</p>
					</div>
					<a href="{{ path('app_artists') }}" class="section__link">
						Voir tous les artistes
						<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
					</a>
				</div>

				<div class="artists-grid">
					{% if featuredArtists is empty %}
						<p class="section__empty reveal">Aucun artiste n'est encore inscrit.</p>
					{% else %}
						{% for artist in featuredArtists %}
							{% set initials = artist.stageName|trim is not empty
              ? (artist.stageName|split(' ')|slice(0, 2)|map(v => v|slice(0, 1)|upper)|join)
              : '?'
            %}
							{% set thumb_path = artist.profilePicture ? artist.profilePicture|replace({'/profile/': '/profile/thumbs/'}) : null %}

							<article class="artist-card reveal">
								<a href="{{ path('app_artist_profile_show', { slug: artist.slug }) }}" class="artist-card__image-wrap">
									{% if thumb_path %}
										<img src="{{ asset('uploads/' ~ thumb_path) }}" alt="{{ artist.stageName }}" class="artist-card__image" loading="lazy">
									{% else %}
										<div class="artist-card__placeholder" aria-hidden="true">
											<span class="artist-card__placeholder-initials">{{ initials }}</span>
										</div>
									{% endif %}
									<div class="artist-card__overlay"></div>
								</a>
								<div class="artist-card__body">
									<div class="artists-list-card__heading">
										<h3 class="artist-card__name artists-list-card__name">
											<a href="{{ path('app_artist_profile_show', { slug: artist.slug }) }}">{{ artist.stageName }}</a>
										</h3>
										{% if artist.isCertified %}
											<span class="artists-list-card__badge" title="Artiste vérifié">
												<svg width="14" height="14" viewbox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
												Vérifié
											</span>
										{% endif %}
									</div>

									<div class="artists-list-card__genres{% if artist.genres|length == 0 %} artists-list-card__genres--empty{% endif %}">
										{% for genre in artist.genres|slice(0, 3) %}
											<span class="badge badge--genre">{{ genre.name }}</span>
										{% endfor %}
										{% if artist.genres|length > 3 %}
											<span class="badge badge--genre artists-list-card__genres-more">+{{ artist.genres|length - 3 }}</span>
										{% endif %}
									</div>

									{% if artist.city or artist.country %}
										<p class="artists-list-card__location">
											<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
											{{ [artist.city, artist.country]|filter(v => v)|join(', ') }}
										</p>
									{% endif %}

									<div class="artist-card__footer">
										<a href="{{ path('app_artist_profile_show', { slug: artist.slug }) }}" class="btn btn--outline-primary btn--sm btn--block">Voir le profil</a>
									</div>
								</div>
							</article>
						{% endfor %}
					{% endif %}
				</div>
			</div>
		</section>

		<!-- Section : Dernières annonces -->
		<section class="section section--warm" id="opportunites">
			{% set announcement_type_labels = {
      'seeking_musician': 'Recherche musicien',
      'seeking_group': 'Recherche groupe',
      'seeking_collaboration': 'Collaboration',
      'seeking_teacher': 'Recherche professeur',
      'seeking_student': 'Recherche élève',
      'other': 'Autre'
    } %}
			<div class="container">
				<div class="section__header reveal">
					<div>
						<h2 class="section__title">Dernières annonces</h2>
						<p class="section__subtitle">Les annonces récemment publiées par les utilisateurs de la plateforme</p>
					</div>
					<a href="#" class="section__link">
						Voir toutes les annonces
						<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
					</a>
				</div>

				<div class="opportunities-grid">
					{% if latestAnnouncements is empty %}
						<p class="section__empty reveal">Aucune annonce publiée pour le moment.</p>
					{% else %}
						{% for announcement in latestAnnouncements %}
							<article class="opportunity-card reveal">
								<span class="opportunity-card__label">
									<svg width="12" height="12" viewbox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="4"/></svg>
									{{ announcement_type_labels[announcement.announcementType.value] }}
								</span>
								<h3 class="opportunity-card__title">{{ announcement.title }}</h3>
								{% if announcement.genres|length > 0 %}
									<div class="opportunity-card__meta">
										{% for genre in announcement.genres|slice(0, 2) %}
											<span class="badge badge--genre">{{ genre.name }}</span>
										{% endfor %}
										{% if announcement.genres|length > 2 %}
											<span class="badge badge--genre">+{{ announcement.genres|length - 2 }}</span>
										{% endif %}
									</div>
								{% endif %}
								{% if announcement.publishedAt %}
									<p class="opportunity-card__date">
										<time datetime="{{ announcement.publishedAt|date('Y-m-d') }}">Publié le
											{{ announcement.publishedAt|date('d/m/Y') }}</time>
									</p>
								{% endif %}
								{% if announcement.city %}
									<p class="opportunity-card__location">
										<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
										{{ announcement.city }}
									</p>
								{% endif %}
								<div class="opportunity-card__footer">
									<a href="#" class="opportunity-card__cta">
										Voir l'annonce
										<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
									</a>
								</div>
							</article>
						{% endfor %}
					{% endif %}
				</div>
			</div>
		</section>

		<!-- Section : Dernières vidéos -->
		<section class="section section--dark" id="dernieres-videos">
			<div class="container">
				<div class="section__header reveal">
					<div>
						<h2 class="section__title">Dernières vidéos</h2>
						<p class="section__subtitle">Les performances les plus récentes de notre communauté</p>
					</div>
				</div>

				<div class="videos-grid">
					<article class="video-card reveal">
						<div class="video-card__thumb">
							<img src="{{ asset('images/videos/midnight-blues.jpg') }}" alt="Midnight Blues Session" loading="lazy">
							<div class="video-card__play">
								<span class="video-card__play-btn">
									<svg width="24" height="24" viewbox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
								</span>
							</div>
							<span class="video-card__duration">4:32</span>
						</div>
						<div class="video-card__body">
							<h3 class="video-card__title">Midnight Blues Session — John Smith</h3>
							<div class="video-card__meta">
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
									12 450 vues</span>
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
									892 likes</span>
							</div>
						</div>
					</article>

					<article class="video-card reveal">
						<div class="video-card__thumb">
							<img src="{{ asset('images/videos/neon-dreams.jpg') }}" alt="Neon Dreams" loading="lazy">
							<div class="video-card__play">
								<span class="video-card__play-btn">
									<svg width="24" height="24" viewbox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
								</span>
							</div>
							<span class="video-card__duration">3:18</span>
						</div>
						<div class="video-card__body">
							<h3 class="video-card__title">Neon Dreams — Luna Waves</h3>
							<div class="video-card__meta">
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
									8 720 vues</span>
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
									654 likes</span>
							</div>
						</div>
					</article>

					<article class="video-card reveal">
						<div class="video-card__thumb">
							<img src="{{ asset('images/videos/flow-state.jpg') }}" alt="Flow State" loading="lazy">
							<div class="video-card__play">
								<span class="video-card__play-btn">
									<svg width="24" height="24" viewbox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
								</span>
							</div>
							<span class="video-card__duration">5:01</span>
						</div>
						<div class="video-card__body">
							<h3 class="video-card__title">Flow State — MC Horizon</h3>
							<div class="video-card__meta">
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
									15 300 vues</span>
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
									1 204 likes</span>
							</div>
						</div>
					</article>

					<article class="video-card reveal">
						<div class="video-card__thumb">
							<img src="{{ asset('images/videos/acoustic-sunrise.jpg') }}" alt="Acoustic Sunrise" loading="lazy">
							<div class="video-card__play">
								<span class="video-card__play-btn">
									<svg width="24" height="24" viewbox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
								</span>
							</div>
							<span class="video-card__duration">6:15</span>
						</div>
						<div class="video-card__body">
							<h3 class="video-card__title">Acoustic Sunrise — Les Échos</h3>
							<div class="video-card__meta">
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
									5 890 vues</span>
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
									478 likes</span>
							</div>
						</div>
					</article>

					<article class="video-card reveal">
						<div class="video-card__thumb">
							<img src="{{ asset('images/videos/deep-pulse.jpg') }}" alt="Deep Pulse Live" loading="lazy">
							<div class="video-card__play">
								<span class="video-card__play-btn">
									<svg width="24" height="24" viewbox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
								</span>
							</div>
							<span class="video-card__duration">7:44</span>
						</div>
						<div class="video-card__body">
							<h3 class="video-card__title">Deep Pulse Live — DJ Nova</h3>
							<div class="video-card__meta">
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
									9 120 vues</span>
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
									723 likes</span>
							</div>
						</div>
					</article>

					<article class="video-card reveal">
						<div class="video-card__thumb">
							<img src="{{ asset('images/videos/velvet-voice.jpg') }}" alt="Velvet Voice" loading="lazy">
							<div class="video-card__play">
								<span class="video-card__play-btn">
									<svg width="24" height="24" viewbox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z"/></svg>
								</span>
							</div>
							<span class="video-card__duration">3:55</span>
						</div>
						<div class="video-card__body">
							<h3 class="video-card__title">Velvet Voice — Amara Soul</h3>
							<div class="video-card__meta">
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
									6 340 vues</span>
								<span>
									<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
									567 likes</span>
							</div>
						</div>
					</article>
				</div>
			</div>
		</section>

		<!-- Section : Comment ça marche -->
		<section class="section section--warm" id="comment-ca-marche">
			<div class="container">
				<div class="section__header section__header--center reveal">
					<h2 class="section__title">Comment ça marche ?</h2>
					<p class="section__subtitle">Trois étapes simples pour rejoindre l'écosystème TalentConnect</p>
				</div>

				<div class="steps">
					<article class="step reveal">
						<div class="step__number">1</div>
						<svg class="step__icon" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
							<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
						</svg>
						<h3 class="step__title">Créer votre profil</h3>

						<p class="step__text">Présentez votre parcours, vos styles musicaux et vos compétences.</p>

					</article>

					<article class="step reveal">
						<div class="step__number">2</div>
						<svg class="step__icon" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
							<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/>
						</svg>
						<h3 class="step__title">Trouvez des opportunités</h3>

						<p class="step__text">Consultez les annonces publiées par la communauté et trouvez votre prochaine collaboration.</p>

					</article>

					<article class="step reveal">
						<div class="step__number">3</div>
						<svg class="step__icon" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
							<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
						</svg>
						<h3 class="step__title">Renforcez votre réseau</h3>

						<p class="step__text">Découvrez de nouveaux artistes, groupes et professionnels près de chez vous et développez vos collaborations.</p>


					</article>
				</div>
			</div>
		</section>
	</main>
{% endblock %}
